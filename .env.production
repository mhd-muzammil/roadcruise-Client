# Loaded by Vite at build time for `npm run build` (production mode).
# The deployed frontend calls this API base. Without it, the build falls back to
# http://localhost:5000/api (see src/utils/api.js), so a deployed site would try
# to reach the visitor's own machine and every request would fail.
# Must be the PUBLIC backend URL, including the /api suffix.
# Current (temporary) deployed backend. Change to https://api.roadcruise.in/api
# once the final domain is live.
VITE_API_URL=https://rc.systimus.in/api
